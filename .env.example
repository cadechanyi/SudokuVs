# Copy to `.env.local` for `next dev` / `next build` on your machine (Next.js reads this file).

# Public origin of the site (no trailing slash). Used for metadataBase and future absolute URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: REST API base when you add a backend (no trailing slash).
NEXT_PUBLIC_API_URL=

# WebSocket URL for multiplayer (browser connects here). Local dev: run `npm run dev:ws` then use
# ws://localhost:3847 (or leave unset on localhost — the app defaults to port 3847).
NEXT_PUBLIC_WS_URL=ws://localhost:3847

# Docker Compose uses `docker.env` (committed defaults). Edit that file or override variables
# when running `docker compose up`.
